#!/usr/bin/env bash
set -euo pipefail

STRICT=false

case "${1:-}" in
  "") ;;
  --strict) STRICT=true ;;
  --help|-h)
    echo "Usage: ./bin/check-harness [--strict]"
    echo "Read-only check for the optional machine-level ECC harness."
    exit 0
    ;;
  *)
    echo "Unknown option: $1" >&2
    exit 2
    ;;
esac

resolve_command() {
  if command -v "$1" >/dev/null 2>&1; then
    command -v "$1"
  elif [ -x "$HOME/.local/bin/$1" ]; then
    printf '%s\n' "$HOME/.local/bin/$1"
  else
    return 1
  fi
}

DOCTOR="$(resolve_command harness-doctor || true)"
SEARCH="$(resolve_command harness-search || true)"
CATALOG="$(resolve_command harness-catalog || true)"
missing=()
[ -n "$DOCTOR" ] || missing+=("harness-doctor")
[ -n "$SEARCH" ] || missing+=("harness-search")
[ -n "$CATALOG" ] || missing+=("harness-catalog")

if [ "${#missing[@]}" -gt 0 ]; then
  echo "[ados] Shared ECC harness unavailable: missing ${missing[*]}"
  echo "[ados] ADOS project-local assets remain usable; install the global base through the machine harness manager."
  if $STRICT; then exit 1; fi
  exit 0
fi

doctor_args=()
if $STRICT; then doctor_args+=(--strict); fi
"$DOCTOR" "${doctor_args[@]}"
"$CATALOG" verify --json >/dev/null
"$SEARCH" --kind agent planner --limit 1 --json >/dev/null

compatibility_ok=true
require_capability() {
  local kind="$1"
  local query="$2"
  local expected_id="$3"
  local result
  if ! result="$("$SEARCH" --kind "$kind" "$query" --limit 10 --json)"; then
    echo "[ados] Shared harness search failed while checking: $expected_id" >&2
    compatibility_ok=false
    return 0
  fi
  if ! grep -Fq "\"id\": \"$expected_id\"" <<<"$result"; then
    echo "[ados] Shared harness is missing required capability: $expected_id" >&2
    compatibility_ok=false
  fi
}

require_capability router growth-marketing anti:router:growth-marketing
require_capability router design-production anti:router:design-production
require_capability skill anti-ai-slop anti:skill:anti-ai-slop
require_capability skill product-marketing anti:library:product-marketing
require_capability skill setup-gbrain anti:library:setup-gbrain

if ! $compatibility_ok; then
  echo "[ados] Shared ECC harness is installed but lacks the retained-skill contract."
  if $STRICT; then exit 1; fi
  exit 0
fi

echo "[ados] Shared ECC harness is healthy, searchable, and retained-skill compatible."
