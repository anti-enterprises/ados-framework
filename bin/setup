#!/usr/bin/env bash
set -euo pipefail

# ados-framework setup script
# Installs owned assets into the current project and optionally pulls upstream dependencies.
#
# Usage:
#   ./bin/setup [--minimal | --full | --dry-run] [--agents=claude|codex|both]
#
# Modes:
#   --minimal   Install only owned assets (agents, commands, helpers, execute-plan)
#   --full      Install owned assets + pull all upstream dependencies
#   --dry-run   Show what would be installed without making changes
#   --agents    Install agent-specific assets. Default: claude
#   (default)   Same as --minimal --agents=claude

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
TARGET_DIR="${ADOS_TARGET_DIR:-$(pwd)}"
MODE="--minimal"
DRY_RUN=false
AGENTS="claude"

usage() {
    echo "Usage: ./bin/setup [--minimal | --full | --dry-run] [--agents=claude|codex|both]"
    echo ""
    echo "  --minimal   Install owned assets only (default)"
    echo "  --full      Install owned assets + upstream dependencies"
    echo "  --dry-run   Preview what would be installed"
    echo "  --agents=claude|codex|both"
    echo "              Install Claude Code assets, Codex assets, or both (default: claude)"
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --dry-run) DRY_RUN=true ;;
    --minimal|--full) MODE="$1" ;;
    --agents=*) AGENTS="${1#--agents=}" ;;
    --agents)
      shift
      if [ "$#" -eq 0 ]; then
        echo "Missing value for --agents"
        exit 1
      fi
      AGENTS="$1"
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      echo "Run ./bin/setup --help for usage"
      exit 1
      ;;
  esac
  shift
done

case "$AGENTS" in
  claude|codex|both) ;;
  *)
    echo "Invalid --agents value: $AGENTS"
    echo "Expected: claude, codex, or both"
    exit 1
    ;;
esac

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { echo -e "${BLUE}[ados]${NC} $*"; }
ok()    { echo -e "${GREEN}[ados]${NC} $*"; }
warn()  { echo -e "${YELLOW}[ados]${NC} $*"; }
err()   { echo -e "${RED}[ados]${NC} $*"; }

# ---------------------------------------------------------------------------
# Preflight checks
# ---------------------------------------------------------------------------

info "ados-framework setup"
info "Source:  $SCRIPT_DIR"
info "Target:  $TARGET_DIR"
info "Mode:    $MODE"
info "Agents:  $AGENTS"
echo ""

if [ "$AGENTS" != "codex" ] && ! $DRY_RUN && [ ! -d "$HOME/.claude" ]; then
  err "Claude Code not detected (~/.claude/ not found)"
  err "Install Claude Code first: https://claude.ai/code"
  exit 1
fi

# ---------------------------------------------------------------------------
# Copy helper: respects --dry-run
# ---------------------------------------------------------------------------

copy_dir() {
  local src="$1" dst="$2" label="$3"
  local count
  count=$(find "$src" -type f | wc -l | tr -d ' ')

  if $DRY_RUN; then
    info "[dry-run] Would copy $count files: $label"
  else
    mkdir -p "$dst"
    cp -R "$src"/* "$dst"/ 2>/dev/null || true
    ok "Copied $count files: $label"
  fi
}

# ---------------------------------------------------------------------------
# Phase 1: Owned assets
# ---------------------------------------------------------------------------

info "=== Phase 1: Installing owned assets ==="
echo ""

# Commands
if [ "$AGENTS" = "claude" ] || [ "$AGENTS" = "both" ]; then
  copy_dir "$SCRIPT_DIR/.claude/commands" "$TARGET_DIR/.claude/commands" "Claude slash commands"

  # Agents
  copy_dir "$SCRIPT_DIR/.claude/agents" "$TARGET_DIR/.claude/agents" "Claude agent definitions"

  # Helpers
  copy_dir "$SCRIPT_DIR/.claude/helpers" "$TARGET_DIR/.claude/helpers" "Claude hook handlers"
fi

if [ "$AGENTS" = "codex" ] || [ "$AGENTS" = "both" ]; then
  copy_dir "$SCRIPT_DIR/.agents/skills" "$TARGET_DIR/.agents/skills" "Codex skill wrappers"
  if $DRY_RUN; then
    info "[dry-run] Would copy AGENTS.md"
  else
    cp "$SCRIPT_DIR/AGENTS.md" "$TARGET_DIR/AGENTS.md"
    ok "Copied AGENTS.md"
  fi
fi

# Execute-plan pipeline
copy_dir "$SCRIPT_DIR/scripts/execute-plan" "$TARGET_DIR/scripts/execute-plan" "execute-plan pipeline"

# Tests
copy_dir "$SCRIPT_DIR/tests/execute-plan" "$TARGET_DIR/tests/execute-plan" "execute-plan tests"

# Skills
copy_dir "$SCRIPT_DIR/skills" "$TARGET_DIR/skills" "bundled skills (root compatibility)"

if [ "$AGENTS" = "claude" ] || [ "$AGENTS" = "both" ]; then
  copy_dir "$SCRIPT_DIR/skills" "$TARGET_DIR/.claude/skills" "Claude bundled skills"
fi

if [ "$AGENTS" = "codex" ] || [ "$AGENTS" = "both" ]; then
  copy_dir "$SCRIPT_DIR/skills" "$TARGET_DIR/.agents/skills" "Codex bundled skills"
fi

# Developer skill catalog
copy_dir "$SCRIPT_DIR/config" "$TARGET_DIR/config" "ADOS configuration"

# Spec Kit preset and extension assets
copy_dir "$SCRIPT_DIR/spec-kit" "$TARGET_DIR/spec-kit" "Spec Kit ADOS assets"

# Config
if $DRY_RUN; then
  info "[dry-run] Would copy claude-flow config"
else
  mkdir -p "$TARGET_DIR/.claude-flow"
  if [ ! -f "$TARGET_DIR/.claude-flow/config.yaml" ]; then
    cp "$SCRIPT_DIR/config/claude-flow.yaml" "$TARGET_DIR/.claude-flow/config.yaml"
    ok "Created .claude-flow/config.yaml"
  else
    warn ".claude-flow/config.yaml already exists, skipping"
  fi
fi

# Settings template
if [ "$AGENTS" = "claude" ] || [ "$AGENTS" = "both" ]; then
  if $DRY_RUN; then
    info "[dry-run] Would merge settings template"
  else
    if [ ! -f "$TARGET_DIR/.claude/settings.json" ]; then
      cp "$SCRIPT_DIR/.claude/settings.template.json" "$TARGET_DIR/.claude/settings.json"
      ok "Created .claude/settings.json from template"
    else
      warn ".claude/settings.json already exists"
      info "Merge manually from: $SCRIPT_DIR/.claude/settings.template.json"
    fi
  fi
fi

echo ""

# ---------------------------------------------------------------------------
# Phase 2: Upstream dependencies (--full only)
# ---------------------------------------------------------------------------

if [ "$MODE" = "--full" ]; then
  info "=== Phase 2: Installing upstream dependencies ==="
  echo ""

  # claude-flow MCP
  if command -v npx &>/dev/null; then
    if $DRY_RUN; then
      info "[dry-run] Would configure claude-flow MCP server"
    else
      info "Configuring claude-flow MCP server..."
      claude mcp add claude-flow -- npx -y @claude-flow/cli@latest mcp start 2>/dev/null && \
        ok "claude-flow MCP configured" || \
        warn "claude-flow MCP setup failed — configure manually: claude mcp add claude-flow -- npx -y @claude-flow/cli@latest mcp start"
    fi
  else
    warn "npx not found — install Node.js to use claude-flow"
  fi

  # gstack
  if [ -d "$HOME/.claude/skills/gstack" ]; then
    ok "gstack already installed at ~/.claude/skills/gstack"
  else
    if $DRY_RUN; then
      info "[dry-run] Would install gstack from garrytan/gstack"
    else
      info "Installing gstack..."
      git clone --depth 1 https://github.com/garrytan/gstack.git "$HOME/.claude/skills/gstack" && \
        cd "$HOME/.claude/skills/gstack" && ./setup && \
        ok "gstack installed" || \
        warn "gstack install failed — install manually: git clone https://github.com/garrytan/gstack.git ~/.claude/skills/gstack && cd ~/.claude/skills/gstack && ./setup"
    fi
  fi

  # Superpowers plugin
  if [ -d "$HOME/.claude/plugins/cache/claude-plugins-official/superpowers" ]; then
    ok "superpowers plugin already installed"
  else
    if $DRY_RUN; then
      info "[dry-run] Would install superpowers plugin"
    else
      info "Installing superpowers plugin..."
      claude plugins install superpowers@claude-plugins-official 2>/dev/null && \
        ok "superpowers installed" || \
        warn "superpowers install failed — install manually: claude plugins install superpowers@claude-plugins-official"
    fi
  fi

  # Frontend design plugin
  if [ -d "$HOME/.claude/plugins/cache/claude-plugins-official/frontend-design" ]; then
    ok "frontend-design plugin already installed"
  else
    if $DRY_RUN; then
      info "[dry-run] Would install frontend-design plugin"
    else
      info "Installing frontend-design plugin..."
      claude plugins install frontend-design@claude-plugins-official 2>/dev/null && \
        ok "frontend-design installed" || \
        warn "frontend-design install failed — install manually"
    fi
  fi

  # Spec Kit CLI
  if command -v specify &>/dev/null; then
    ok "Spec Kit specify CLI already available"
  elif command -v uvx &>/dev/null; then
    if $DRY_RUN; then
      info "[dry-run] Would use uvx for Spec Kit specify CLI"
    else
      ok "Spec Kit can be run with: uvx --from git+https://github.com/github/spec-kit.git specify"
    fi
  elif command -v pipx &>/dev/null; then
    if $DRY_RUN; then
      info "[dry-run] Would install Spec Kit specify CLI with pipx"
    else
      info "Installing Spec Kit specify CLI..."
      pipx install git+https://github.com/github/spec-kit.git && \
        ok "Spec Kit specify CLI installed" || \
        warn "Spec Kit install failed — install manually: pipx install git+https://github.com/github/spec-kit.git"
    fi
  else
    warn "uvx/pipx not found — install Spec Kit manually: https://github.com/github/spec-kit"
  fi

  echo ""
fi

# ---------------------------------------------------------------------------
# Phase 3: TypeScript dependencies
# ---------------------------------------------------------------------------

if [ -f "$TARGET_DIR/package.json" ]; then
  if $DRY_RUN; then
    info "[dry-run] Would install npm dependencies"
  else
    info "Installing npm dependencies..."
    cd "$TARGET_DIR"
    if command -v pnpm &>/dev/null; then
      pnpm install --silent && ok "Dependencies installed (pnpm)"
    elif command -v npm &>/dev/null; then
      npm install --silent && ok "Dependencies installed (npm)"
    else
      warn "No package manager found — run 'npm install' manually"
    fi
  fi
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------

echo ""
info "=== Setup Complete ==="
echo ""
ok "Owned assets installed to $TARGET_DIR"
if [ "$MODE" = "--full" ]; then
  ok "Upstream dependencies configured"
fi
echo ""
info "Next steps:"
info "  1. Review .claude/settings.json (merge template if needed)"
info "  2. Run 'npx vitest run' to verify tests pass"
info "  3. Try '/execute-plan --dry-run' with a plan file"
info "  4. For Spec Kit: 'specify init --here --integration claude' or 'specify init --here --integration codex --integration-options=\"--skills\"'"
info "  5. Install ADOS Spec Kit assets with 'specify preset add --dev spec-kit/presets/ados' and 'specify extension add --dev spec-kit/extensions/ados-execute-plan'"
echo ""
